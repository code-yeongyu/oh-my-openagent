    "mobile-xcode": {
      "model": "google/gemini-3-pro-preview"
    },
    "mobile-react-native": {
      "model": "google/gemini-3-pro-preview"
    },
    "ai-ml-expert": {
      "model": "google/gemini-3-flash-preview"
    },
    "agent-specialist": {
      "model": "google/gemini-3-flash-preview"
    },
    "security-specialist": {
      "model": "google/gemini-3-flash-preview"
    },
    "test-specialist": {
      "model": "google/gemini-3-flash-preview"
