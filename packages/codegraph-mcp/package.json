{
  "name": "@oh-my-opencode/codegraph-mcp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Freshness-preserving stdio MCP proxy for CodeGraph.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "bin": {
    "omo-codegraph-mcp": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/cli.ts --outdir dist --target node --format esm",
    "qa:multi-repo": "node qa/manual-multi-repo.mjs",
    "test": "bun test src/*.test.ts src/**/*.test.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@oh-my-opencode/mcp-stdio-core": "workspace:*",
    "@oh-my-opencode/utils": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "1.3.14"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
