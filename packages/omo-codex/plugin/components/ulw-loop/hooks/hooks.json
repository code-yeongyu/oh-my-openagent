{
	"hooks": {
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/dist/cli.js\" hook user-prompt-submit",
						"timeout": 10,
						"statusMessage": "LazyCodex(0.1.0): Checking Ulw-Loop Steering"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "^(create_goal|wait_agent|update_goal|update_plan)$",
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/dist/cli.js\" hook pre-tool-use",
						"timeout": 5,
						"statusMessage": "LazyCodex(0.1.0): Enforcing Ulw-Loop Orchestration"
					}
				]
			}
		]
	}
}
