{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" rules hook session-start",
            "timeout": 10,
            "statusMessage": "(OmO) Loading Project Rules"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" telemetry hook session-start",
            "timeout": 5,
            "statusMessage": "(OmO) Recording Session Telemetry"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" rules hook user-prompt-submit",
            "timeout": 10,
            "statusMessage": "(OmO) Loading Project Rules"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" ultrawork hook user-prompt-submit",
            "timeout": 5,
            "statusMessage": "(OmO) Checking Ultrawork Trigger"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" ulw-loop hook user-prompt-submit",
            "timeout": 10,
            "statusMessage": "(OmO) Checking Ulw-Loop Steering"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" comment-checker hook post-tool-use",
            "timeout": 30,
            "statusMessage": "(OmO) Checking Comments"
          }
        ],
        "matcher": "^(apply_patch|write|Write|edit|Edit|multi_edit|multiedit|MultiEdit)$"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" rules hook post-tool-use",
            "timeout": 10,
            "statusMessage": "(OmO) Matching Project Rules"
          }
        ],
        "matcher": "^apply_patch$"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" lsp hook post-tool-use",
            "timeout": 60,
            "statusMessage": "(OmO) Checking LSP Diagnostics"
          }
        ],
        "matcher": "^(apply_patch|write|Write|edit|Edit|multi_edit|multiedit|MultiEdit)$"
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" lsp hook post-compact",
            "timeout": 5,
            "statusMessage": "(OmO) Resetting LSP Diagnostics Cache"
          }
        ],
        "matcher": "manual|auto"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" rules hook post-compact",
            "timeout": 10,
            "statusMessage": "(OmO) Resetting Project Rule Cache"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${SENPI_HOOK_SOURCE%/hooks/omo-senpi-hooks.json}/components/run-hook.mjs\" start-work-continuation hook stop",
            "timeout": 10,
            "statusMessage": "(OmO) Checking Start-Work Continuation"
          }
        ]
      }
    ]
  }
}
