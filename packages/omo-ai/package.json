{
  "name": "omo-ai",
  "version": "4.15.0",
  "description": "OMO senpi adapter package skeleton.",
  "type": "module",
  "bin": {
    "omo-ai": "./src/cli/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./doctor": {
      "types": "./src/doctor/index.ts",
      "import": "./src/doctor/index.ts"
    },
    "./install": {
      "types": "./src/install/index.ts",
      "import": "./src/install/index.ts"
    },
    "./senpi-compat": {
      "types": "./src/senpi-compat/index.ts",
      "import": "./src/senpi-compat/index.ts"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "postinstall": "node ./src/install/postinstall.mjs",
    "test": "bun test test/**/*.test.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "keywords": [
    "omo",
    "senpi",
    "pi-package"
  ],
  "pi": {
    "hooks": "./senpi/hooks",
    "skills": "./senpi/skills",
    "prompts": "./senpi/prompts",
    "extensions": "./senpi/extensions"
  },
  "license": "SUL-1.0",
  "devDependencies": {
    "bun-types": "1.3.14"
  }
}
